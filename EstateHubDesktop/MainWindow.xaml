<Window x:Class="EstateHubDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EstateHub Desktop"
        Width="1280"
        Height="820"
        MinWidth="1080"
        MinHeight="720"
        Background="#E7E8EA"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="BlueBrush" Color="#5694B8" />
        <SolidColorBrush x:Key="SoftBlueBrush" Color="#D9EEF7" />
        <SolidColorBrush x:Key="PageBrush" Color="#E7E8EA" />
        <SolidColorBrush x:Key="MutedBrush" Color="#666666" />

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource BlueBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="#35769A" />
            <Setter Property="Background" Value="#D9EEF7" />
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="#B42318" />
            <Setter Property="Background" Value="#FFF0EE" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="BorderBrush" Value="#4B94BD" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderBrush" Value="#4B94BD" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="42" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="White" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="222" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#4B94BD" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Height="96" BorderBrush="#4B94BD" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="38,0,0,0">
                        <TextBlock Text="⌂" Foreground="#5694B8" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock Text="EstateHub" Margin="8,0,0,0" FontSize="23" FontWeight="Black" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <StackPanel DockPanel.Dock="Bottom" Margin="38,0,0,36">
                    <TextBlock Text="?  Help" Margin="0,0,0,22" FontSize="15" />
                    <TextBlock Text="⚙  Settings" Margin="0,0,0,22" FontSize="15" />
                    <TextBlock Text="↪  Log Out" FontSize="15" />
                </StackPanel>

                <StackPanel Margin="0,40,0,0">
                    <Button x:Name="DashboardNavButton" Content="▦  Overview" Click="DashboardNavButton_Click" Style="{StaticResource SecondaryButton}" HorizontalContentAlignment="Left" Margin="0,0,0,4" />
                    <Button x:Name="ApartmentsNavButton" Content="▤  Apartments" Click="ApartmentsNavButton_Click" Style="{StaticResource SecondaryButton}" HorizontalContentAlignment="Left" Margin="0,0,0,4" />
                    <Button x:Name="TenantsNavButton" Content="☷  Customer Care" Click="TenantsNavButton_Click" Style="{StaticResource SecondaryButton}" HorizontalContentAlignment="Left" Margin="0,0,0,4" />
                    <TextBlock Text="▥  Rentals" Margin="38,18,0,0" FontSize="15" />
                    <TextBlock Text="▧  Accounting" Margin="38,24,0,0" FontSize="15" />
                    <TextBlock Text="▨  Inspections" Margin="38,24,0,0" FontSize="15" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="96" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#4B94BD" BorderThickness="0,0,0,1">
                <DockPanel Margin="26,0,40,0">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="44" Height="44" CornerRadius="22" BorderBrush="#4B94BD" BorderThickness="1" Background="#EDF8FC">
                            <TextBlock Text="◦" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#4B94BD" FontSize="24" />
                        </Border>
                        <Border Width="1" Height="28" Background="#4B94BD" Margin="36,0,36,0" />
                        <Ellipse Width="44" Height="44" Fill="#999999" />
                        <StackPanel Margin="14,0,26,0" VerticalAlignment="Center">
                            <TextBlock Text="Viktor Nilsson" FontWeight="Bold" />
                            <TextBlock Text="EstateHub" Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>
                        <TextBlock Text="⌄" FontSize="24" VerticalAlignment="Center" />
                    </StackPanel>

                    <Border Width="338" Height="42" BorderBrush="#4B94BD" BorderThickness="1" CornerRadius="14" VerticalAlignment="Center">
                        <DockPanel Margin="14,0">
                            <TextBlock Text="⌕" Foreground="#4B94BD" FontSize="20" VerticalAlignment="Center" />
                            <TextBox x:Name="GlobalSearchTextBox" BorderThickness="0" Margin="10,0,0,0" TextChanged="GlobalSearchTextBox_TextChanged" />
                        </DockPanel>
                    </Border>
                </DockPanel>
            </Border>

            <TabControl x:Name="MainTabs" Grid.Row="1" Background="#E7E8EA" BorderThickness="0" Padding="26,36,40,36">
                <TabItem Header="Overview">
                    <ScrollViewer>
                        <StackPanel>
                            <TextBlock Text="EstateHub Desktop" FontSize="34" FontWeight="Black" Margin="0,0,0,22" />
                            <UniformGrid Columns="4" Margin="0,0,0,30">
                                <Border Background="White" CornerRadius="11" Padding="22" Margin="0,0,16,0">
                                    <StackPanel>
                                        <TextBlock Text="Apartments" Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock x:Name="ApartmentCountText" Text="-" FontSize="30" FontWeight="Black" />
                                    </StackPanel>
                                </Border>
                                <Border Background="White" CornerRadius="11" Padding="22" Margin="0,0,16,0">
                                    <StackPanel>
                                        <TextBlock Text="Vacant" Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock x:Name="VacantCountText" Text="-" FontSize="30" FontWeight="Black" />
                                    </StackPanel>
                                </Border>
                                <Border Background="White" CornerRadius="11" Padding="22" Margin="0,0,16,0">
                                    <StackPanel>
                                        <TextBlock Text="Tenants" Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock x:Name="TenantCountText" Text="-" FontSize="30" FontWeight="Black" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#5694B8" CornerRadius="11" Padding="22">
                                    <StackPanel>
                                        <TextBlock Text="Total Rent" Foreground="White" Opacity=".8" />
                                        <TextBlock x:Name="TotalRentText" Text="-" Foreground="White" FontSize="30" FontWeight="Black" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Border Background="White" CornerRadius="11" Padding="22">
                                <StackPanel>
                                    <TextBlock Text="Quick Search" FontSize="22" FontWeight="Bold" Margin="0,0,0,12" />
                                    <TextBlock Text="Use the top search field to filter apartments and tenants." Foreground="{StaticResource MutedBrush}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Apartments">
                    <ScrollViewer>
                        <StackPanel>
                            <DockPanel Margin="0,0,0,22">
                                <Button DockPanel.Dock="Right" Content="+ Add Apartment" Click="ToggleApartmentFormButton_Click" />
                                <TextBlock Text="Apartments" FontSize="34" FontWeight="Black" />
                            </DockPanel>

                            <Border Background="White" CornerRadius="11" Padding="18" Margin="0,0,0,24">
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="ApartmentStatusFilter" Width="170" SelectionChanged="ApartmentStatusFilter_SelectionChanged">
                                        <ComboBoxItem Content="Property Type..." IsSelected="True" />
                                        <ComboBoxItem Content="Ledig" />
                                        <ComboBoxItem Content="Uthyrd" />
                                        <ComboBoxItem Content="Reserverad" />
                                        <ComboBoxItem Content="Renoveras" />
                                    </ComboBox>
                                    <TextBox x:Name="ApartmentSearchTextBox" Width="260" Margin="14,0,0,0" TextChanged="ApartmentSearchTextBox_TextChanged" />
                                    <Button Content="Search" Margin="14,0,0,0" Click="ApartmentSearchButton_Click" />
                                </StackPanel>
                            </Border>

                            <Border x:Name="ApartmentFormPanel" Background="White" CornerRadius="11" Padding="22" Margin="0,0,0,24" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="Lägg till lägenhet" FontSize="22" FontWeight="Bold" Margin="0,0,0,16" />
                                    <UniformGrid Columns="4" Rows="3">
                                        <StackPanel Margin="0,0,12,12"><TextBlock Text="Lägenhetsnummer" /><TextBox x:Name="ApartmentNumberInput" /></StackPanel>
                                        <StackPanel Margin="0,0,12,12"><TextBlock Text="Storlek kvm" /><TextBox x:Name="ApartmentSizeInput" /></StackPanel>
                                        <StackPanel Margin="0,0,12,12"><TextBlock Text="Hyra" /><TextBox x:Name="ApartmentRentInput" /></StackPanel>
                                        <StackPanel Margin="0,0,0,12"><TextBlock Text="Fastighet" /><ComboBox x:Name="ApartmentPropertyComboBox" DisplayMemberPath="Address" SelectedValuePath="PropertyId" /></StackPanel>
                                        <StackPanel Margin="0,0,12,12"><TextBlock Text="Rum" /><TextBox x:Name="ApartmentRoomsInput" Text="1" /></StackPanel>
                                        <StackPanel Margin="0,0,12,12"><TextBlock Text="Våning" /><TextBox x:Name="ApartmentFloorInput" Text="0" /></StackPanel>
                                        <StackPanel Margin="0,0,12,12"><TextBlock Text="Status" /><ComboBox x:Name="ApartmentStatusInput"><ComboBoxItem Content="Ledig" IsSelected="True" /><ComboBoxItem Content="Uthyrd" /><ComboBoxItem Content="Reserverad" /><ComboBoxItem Content="Renoveras" /></ComboBox></StackPanel>
                                        <StackPanel Margin="0,0,0,12"><TextBlock Text="Tillgänglig från" /><DatePicker x:Name="ApartmentAvailableInput" /></StackPanel>
                                    </UniformGrid>
                                    <WrapPanel Margin="0,4,0,18">
                                        <CheckBox x:Name="ElectricityIncludedInput" Content="El ingår" Margin="0,0,18,0" />
                                        <CheckBox x:Name="WaterIncludedInput" Content="Vatten ingår" Margin="0,0,18,0" />
                                        <CheckBox x:Name="InternetIncludedInput" Content="Internet ingår" Margin="0,0,18,0" />
                                        <CheckBox x:Name="BalconyInput" Content="Balkong" Margin="0,0,18,0" />
                                        <CheckBox x:Name="FurnishedInput" Content="Möblerad" />
                                    </WrapPanel>
                                    <Button Content="Spara lägenhet" HorizontalAlignment="Left" Click="SaveApartmentButton_Click" />
                                </StackPanel>
                            </Border>

                            <DataGrid x:Name="ApartmentsGrid" SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Lgh" Binding="{Binding ApartmentNumber}" Width="90" />
                                    <DataGridTextColumn Header="Adress" Binding="{Binding Property.Address}" Width="180" />
                                    <DataGridTextColumn Header="Stad" Binding="{Binding Property.City}" Width="120" />
                                    <DataGridTextColumn Header="Kvm" Binding="{Binding Size}" Width="80" />
                                    <DataGridTextColumn Header="Rum" Binding="{Binding Rooms}" Width="80" />
                                    <DataGridTextColumn Header="Hyra" Binding="{Binding Rent}" Width="100" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                                    <DataGridTextColumn Header="Hyresgäst" Binding="{Binding Tenant.FirstName}" Width="140" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Tenants">
                    <ScrollViewer>
                        <StackPanel>
                            <TextBlock Text="Customer Care" FontSize="34" FontWeight="Black" Margin="0,0,0,22" />

                            <Border Background="White" CornerRadius="11" Padding="22" Margin="0,0,0,24">
                                <StackPanel>
                                    <TextBlock x:Name="TenantFormTitle" Text="Registrera ny hyresgäst" FontSize="22" FontWeight="Bold" Margin="0,0,0,16" />
                                    <UniformGrid Columns="4" Rows="2">
                                        <StackPanel Margin="0,0,12,12"><TextBlock Text="Förnamn" /><TextBox x:Name="TenantFirstNameInput" /></StackPanel>
                                        <StackPanel Margin="0,0,12,12"><TextBlock Text="Efternamn" /><TextBox x:Name="TenantLastNameInput" /></StackPanel>
                                        <StackPanel Margin="0,0,12,12"><TextBlock Text="Personnummer" /><TextBox x:Name="TenantPersonalNumberInput" /></StackPanel>
                                        <StackPanel Margin="0,0,0,12"><TextBlock Text="Mobilnummer" /><TextBox x:Name="TenantMobileInput" /></StackPanel>
                                        <StackPanel Margin="0,0,12,0"><TextBlock Text="Telefon" /><TextBox x:Name="TenantPhoneInput" /></StackPanel>
                                        <StackPanel Margin="0,0,12,0"><TextBlock Text="E-post" /><TextBox x:Name="TenantEmailInput" /></StackPanel>
                                        <StackPanel Grid.ColumnSpan="2"><TextBlock Text="Adress" /><TextBox x:Name="TenantAddressInput" /></StackPanel>
                                    </UniformGrid>
                                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                        <Button x:Name="SaveTenantButton" Content="Registrera" Click="SaveTenantButton_Click" />
                                        <Button Content="Avbryt" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="CancelTenantButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="White" CornerRadius="11" Padding="18" Margin="0,0,0,24">
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="TenantSearchTextBox" Width="340" TextChanged="TenantSearchTextBox_TextChanged" />
                                    <Button Content="Rensa" Style="{StaticResource SecondaryButton}" Margin="14,0,0,0" Click="ClearTenantSearchButton_Click" />
                                </StackPanel>
                            </Border>

                            <DataGrid x:Name="TenantsGrid" SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Förnamn" Binding="{Binding FirstName}" Width="120" />
                                    <DataGridTextColumn Header="Efternamn" Binding="{Binding LastName}" Width="130" />
                                    <DataGridTextColumn Header="Personnummer" Binding="{Binding PersonalNumber}" Width="150" />
                                    <DataGridTextColumn Header="Adress" Binding="{Binding Address}" Width="220" />
                                    <DataGridTextColumn Header="Mobil" Binding="{Binding MobilePhone}" Width="130" />
                                    <DataGridTextColumn Header="Telefon" Binding="{Binding Phone}" Width="120" />
                                    <DataGridTextColumn Header="E-post" Binding="{Binding Email}" Width="180" />
                                    <DataGridTemplateColumn Header="Åtgärd" Width="170">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Ändra" Style="{StaticResource SecondaryButton}" Click="EditTenantButton_Click" />
                                                    <Button Content="Ta bort" Style="{StaticResource DangerButton}" Margin="8,0,0,0" Click="DeleteTenantButton_Click" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
